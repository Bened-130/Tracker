{
  "version": 2,
  "name": "Benedict-academy-tracker",
  
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  
  "env": {
    "NODE_ENV": "production"
  }
}